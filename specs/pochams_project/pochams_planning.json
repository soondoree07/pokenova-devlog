{
  "meta": {
    "title": "포챔스 팀 공유 사이트 — Pokemon Champions Team Hub",
    "version": "v4.0",
    "created_at": "2026-04",
    "description": "포켓몬 챔피언스(포챔스) 배틀팀 및 단일 샘플을 공유하고, 공유 데이터 기반 메타 통계와 결정력 계산기를 제공하는 커뮤니티 플랫폼"
  },

  "core_concepts": {
    "sample": {
      "definition": "포켓몬 한 마리의 실전 세트 단위",
      "name_format": "[자유입력 접두사] + '[포켓몬이름] 샘플' (접미사 자동 고정)",
      "name_examples": ["솔라블레이드 리자몽 샘플", "목탄 리자몽 샘플", "리자몽 샘플"],
      "prefix_optional": true
    },
    "stat_points": {
      "description": "포챔스의 EV/IV 대체 시스템",
      "total_cap": 66,
      "per_stat_cap": 32,
      "iv_fixed": 31,
      "effect": "1 SP = 레벨50 실수치 +1 (직접 가산)",
      "formula": {
        "hp": "floor((2 × base_stat_HP + 31) × 50/100 + 60) + SP_HP",
        "others": "floor((2 × base_stat + 31) × 50/100 + 5) × nature_modifier + SP",
        "nature_modifier": { "up": 1.1, "neutral": 1.0, "down": 0.9 },
        "note": "성격보정 적용 위치(SP 가산 전/후) 실제 게임 내 검증 필요"
      }
    },
    "content_types": {
      "battle_team": {
        "description": "6마리 샘플 + 운영방법으로 구성된 실전 팀",
        "rental_code": "선택 입력, 중복 허용",
        "likes": "팀 단위 + 팀 내 샘플 단위 (독립)",
        "stats_contribution": "팀 샘플로 집계",
        "home_section": "팀 목록 섹션",
        "detail_page": "/teams/:id"
      },
      "standalone_sample": {
        "description": "포켓몬 1마리의 기술/도구/특성/SP 세트 단독 공유",
        "likes": "단일 샘플 단위",
        "stats_contribution": "팀 샘플과 동일 가중치로 합산",
        "home_section": "단일 샘플 섹션",
        "detail_page": "/samples/:id"
      }
    }
  },

  "features": {
    "team_registration": {
      "auth_required": true,
      "fields": {
        "required": [
          "team_name",
          "battle_format",
          "description",
          "samples_x6"
        ],
        "optional": [
          "rental_code",
          "season"
        ]
      },
      "battle_format_options": ["싱글", "더블"],
      "sample_fields": {
        "required": [
          "sample_name",
          "pokemon",
          "nature",
          "ability",
          "item",
          "moves_x4",
          "stat_points_x6"
        ],
        "optional": [
          "tera_type"
        ]
      },
      "stat_points_ui": {
        "type": "horizontal_slider",
        "buttons": ["MAX", "MIN"],
        "constraints": {
          "per_stat_max": 32,
          "total_max": 66,
          "realtime_validation": true
