        "리자몽 샘플"
      ],
      "prefix_optional": true
    },
    "stat_points": {
      "description": "포챔스 EV/IV 대체 시스템",
      "total_cap": 66,
      "per_stat_cap": 32,
      "iv_fixed": 31,
      "effect": "1 SP = 레벨50 실수치 +1 직접 가산",
      "formula": {
        "hp": "floor((2 × base_stat_HP + 31) × 50/100 + 60) + SP_HP",
        "others": "floor((2 × base_stat + 31) × 50/100 + 5) × nature_modifier + SP",
        "nature_modifier": {
          "up": 1.1,
          "neutral": 1.0,
          "down": 0.9
        },
        "note": "성격보정 적용 위치(SP 가산 전/후) 실제 게임 내 검증 필요"
      }
    }
  },
