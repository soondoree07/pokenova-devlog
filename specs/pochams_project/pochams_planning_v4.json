      "sample_fields": {
        "required": ["sample_name", "pokemon", "nature", "ability", "item", "moves_x4", "stat_points_x6"],
        "optional": ["tera_type"]
      },
      "stat_points_ui": {
        "type": "horizontal_slider",
        "buttons": ["MAX", "MIN"],
        "realtime_stat_preview": true,
        "constraints": { "per_stat_max": 32, "total_max": 66, "realtime_block": true }
